<!DOCTYPE html>
<html class="light" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>HostelMaster ERP | Premium Student Living</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&amp;display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <!-- FontAwesome for Chatbot and existing icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Legacy Styles (for forms and specific page layouts) -->
    <link rel="stylesheet" href="/css/style.css">

    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#137fec",
                        "background-light": "#f6f7f8",
                        "background-dark": "#101922",
                    },
                    fontFamily: {
                        "display": ["Manrope"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        body {
            font-family: 'Manrope', sans-serif;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        /* Override potential legacy conflicting styles */
        header a {
            text-decoration: none;
        }

        footer a {
            text-decoration: none;
        }
    </style>
</head>

<body class="bg-background-light dark:bg-background-dark text-[#111418] dark:text-white transition-colors duration-200">
    <!-- Top Navigation Bar -->
    <header
        class="sticky top-0 z-50 w-full border-b border-solid border-[#f0f2f4] dark:border-[#2a343f] bg-white/80 dark:bg-background-dark/80 backdrop-blur-md">
        <div class="max-w-[1280px] mx-auto px-6 lg:px-10 py-3 flex items-center justify-between whitespace-nowrap">
            <div class="flex items-center gap-3 text-[#111418] dark:text-white">
                <a href="/" class="flex items-center gap-3 decoration-none text-current">
                    <div class="h-10">
                        <img src="https://crescent.mastersofterp.in/Images/DEFAULT_BG/default_logo1.png"
                            alt="College Logo" class="h-full object-contain">
                    </div>

                </a>
            </div>
            <!-- Desktop Nav -->
            <div class="hidden md:flex flex-1 justify-end gap-8 items-center">
                <nav class="flex items-center gap-8">
                    <a class="text-sm font-medium hover:text-primary transition-colors text-current decoration-none"
                        href="/">Home</a>
                    <a class="text-sm font-medium hover:text-primary transition-colors text-current decoration-none"
                        href="/gatepass">Gatepass</a>
                    <a class="text-sm font-medium hover:text-primary transition-colors text-current decoration-none"
                        href="/maintenance">Maintenance</a>
                    <a class="text-sm font-medium hover:text-primary transition-colors text-current decoration-none"
                        href="/medical">Medical</a>
                    <a class="text-sm font-medium hover:text-primary transition-colors text-current decoration-none"
                        href="/mypasses">My Passes</a>
                </nav>
                <div class="flex gap-3">
                    <% if (user) { %>
                        <div class="flex items-center gap-4">
                            <div class="flex items-center gap-2">
                                <div
                                    class="size-8 rounded-full bg-primary/20 flex items-center justify-center text-primary font-bold">
                                    <% let displayName=user.name || user.username || user.email || 'U' ; let
                                        initial=displayName.charAt(0).toUpperCase(); %>
                                        <%= initial %>
                                </div>
                                <span class="hidden lg:inline text-sm font-medium text-current">
                                    <%= user.name || user.username || (user.email ? user.email.split('@')[0] : 'User' )
                                        %>
                                </span>
                            </div>
                            <a href="/logout"
                                class="flex min-w-[84px] cursor-pointer items-center justify-center rounded-lg h-10 px-4 bg-[#f0f2f4] dark:bg-[#2a343f] text-[#111418] dark:text-white text-sm font-bold hover:opacity-80 decoration-none">
                                Logout
                            </a>
                        </div>
                        <% } else { %>
                            <button
                                class="flex min-w-[100px] cursor-pointer items-center justify-center rounded-lg h-10 px-4 bg-primary text-white text-sm font-bold transition-all hover:bg-primary/90">
                                Book a Demo
                            </button>
                            <a href="/login"
                                class="flex min-w-[84px] cursor-pointer items-center justify-center rounded-lg h-10 px-4 bg-[#f0f2f4] dark:bg-[#2a343f] text-[#111418] dark:text-white text-sm font-bold hover:opacity-80 decoration-none">
                                Login
                            </a>
                            <% } %>
                </div>
            </div>

            <!-- Mobile Hamburger Button -->
            <button id="saas-mobile-toggle" onclick="toggleSaasMenu()"
                class="md:hidden flex flex-col justify-center items-center gap-[5px] p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-[#2a343f] transition-colors"
                aria-label="Toggle menu">
                <span
                    class="saas-hamburger-line block w-5 h-[2px] bg-[#111418] dark:bg-white rounded transition-all duration-300"></span>
                <span
                    class="saas-hamburger-line block w-5 h-[2px] bg-[#111418] dark:bg-white rounded transition-all duration-300"></span>
                <span
                    class="saas-hamburger-line block w-5 h-[2px] bg-[#111418] dark:bg-white rounded transition-all duration-300"></span>
            </button>
        </div>
    </header>

    <!-- Mobile Navigation Drawer -->
    <div id="saas-mobile-nav" class="fixed inset-0 z-40 pointer-events-none md:hidden" style="visibility: hidden;">
        <!-- Backdrop -->
        <div id="saas-mobile-backdrop" class="absolute inset-0 bg-black/0 transition-all duration-300"
            onclick="toggleSaasMenu()"></div>
        <!-- Drawer Panel -->
        <div id="saas-mobile-drawer"
            class="absolute top-0 right-0 h-full w-[280px] max-w-[85vw] bg-white dark:bg-background-dark shadow-2xl translate-x-full transition-transform duration-300 ease-in-out flex flex-col pointer-events-auto">
            <!-- Drawer Header -->
            <div class="flex items-center justify-between p-5 border-b border-[#f0f2f4] dark:border-[#2a343f]">
                <span class="text-base font-bold text-[#111418] dark:text-white">Menu</span>
                <button onclick="toggleSaasMenu()"
                    class="p-1 rounded-lg hover:bg-gray-100 dark:hover:bg-[#2a343f] transition-colors"
                    aria-label="Close menu">
                    <svg class="w-5 h-5 text-[#111418] dark:text-white" fill="none" stroke="currentColor"
                        viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12">
                        </path>
                    </svg>
                </button>
            </div>
            <!-- Drawer Links -->
            <nav class="flex-1 overflow-y-auto py-4 px-3">
                <a href="/"
                    class="flex items-center gap-3 px-4 py-3 rounded-xl text-[#111418] dark:text-white text-sm font-medium hover:bg-gray-50 dark:hover:bg-[#1c2631] transition-colors decoration-none">
                    <span class="material-symbols-outlined text-lg text-primary">home</span> Home
                </a>
                <a href="/gatepass"
                    class="flex items-center gap-3 px-4 py-3 rounded-xl text-[#111418] dark:text-white text-sm font-medium hover:bg-gray-50 dark:hover:bg-[#1c2631] transition-colors decoration-none">
                    <span class="material-symbols-outlined text-lg text-primary">badge</span> Gatepass
                </a>
                <a href="/maintenance"
                    class="flex items-center gap-3 px-4 py-3 rounded-xl text-[#111418] dark:text-white text-sm font-medium hover:bg-gray-50 dark:hover:bg-[#1c2631] transition-colors decoration-none">
                    <span class="material-symbols-outlined text-lg text-primary">build</span> Maintenance
                </a>
                <a href="/medical"
                    class="flex items-center gap-3 px-4 py-3 rounded-xl text-[#111418] dark:text-white text-sm font-medium hover:bg-gray-50 dark:hover:bg-[#1c2631] transition-colors decoration-none">
                    <span class="material-symbols-outlined text-lg text-primary">medical_services</span> Medical
                </a>
                <a href="/mypasses"
                    class="flex items-center gap-3 px-4 py-3 rounded-xl text-[#111418] dark:text-white text-sm font-medium hover:bg-gray-50 dark:hover:bg-[#1c2631] transition-colors decoration-none">
                    <span class="material-symbols-outlined text-lg text-primary">history</span> My Passes
                </a>
            </nav>
            <!-- Drawer Footer (Auth) -->
            <div class="p-4 border-t border-[#f0f2f4] dark:border-[#2a343f]">
                <% if (user) { %>
                    <div class="flex items-center gap-3 mb-4 px-2">
                        <div
                            class="size-10 rounded-full bg-primary/20 flex items-center justify-center text-primary font-bold text-lg">
                            <% let mobileDisplayName=user.name || user.username || user.email || 'U' ; let
                                mobileInitial=mobileDisplayName.charAt(0).toUpperCase(); %>
                                <%= mobileInitial %>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-sm font-bold text-[#111418] dark:text-white">
                                <%= user.name || user.username || 'User' %>
                            </span>
                            <span class="text-xs text-[#617589]">Student</span>
                        </div>
                    </div>
                    <a href="/logout"
                        class="flex items-center justify-center gap-2 w-full py-3 rounded-xl bg-[#f0f2f4] dark:bg-[#2a343f] text-[#111418] dark:text-white text-sm font-bold hover:opacity-80 transition-all decoration-none">
                        <span class="material-symbols-outlined text-lg">logout</span> Logout
                    </a>
                    <% } else { %>
                        <a href="/login"
                            class="flex items-center justify-center gap-2 w-full py-3 rounded-xl bg-primary text-white text-sm font-bold hover:bg-primary/90 transition-all decoration-none">
                            <span class="material-symbols-outlined text-lg">login</span> Login
                        </a>
                        <% } %>
            </div>
        </div>
    </div>

    <script>
        function toggleSaasMenu() {
            const nav = document.getElementById('saas-mobile-nav');
            const drawer = document.getElementById('saas-mobile-drawer');
            const backdrop = document.getElementById('saas-mobile-backdrop');
            const toggle = document.getElementById('saas-mobile-toggle');
            const isOpen = drawer.classList.contains('translate-x-0');

            if (isOpen) {
                drawer.classList.remove('translate-x-0');
                drawer.classList.add('translate-x-full');
                backdrop.classList.remove('bg-black/50');
                backdrop.classList.add('bg-black/0');
                toggle.classList.remove('saas-menu-open');
                document.body.style.overflow = '';
                setTimeout(() => { nav.style.visibility = 'hidden'; nav.classList.add('pointer-events-none'); }, 300);
            } else {
                nav.style.visibility = 'visible';
                nav.classList.remove('pointer-events-none');
                requestAnimationFrame(() => {
                    drawer.classList.remove('translate-x-full');
                    drawer.classList.add('translate-x-0');
                    backdrop.classList.remove('bg-black/0');
                    backdrop.classList.add('bg-black/50');
                    toggle.classList.add('saas-menu-open');
                    document.body.style.overflow = 'hidden';
                });
            }
        }
    </script>

    <main class="w-full min-h-[80vh]">