<%- include('partials/saas_header') %>

    <!-- Welcome Hero Section -->
    <section class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-10 py-8 sm:py-12 lg:py-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
            <div class="flex flex-col gap-4 sm:gap-6 order-2 lg:order-1">
                <div class="flex flex-col gap-2 sm:gap-3 text-left">
                    <h1
                        class="text-[#111418] dark:text-white text-2xl sm:text-3xl font-black leading-tight tracking-tight md:text-4xl lg:text-5xl">
                        Welcome back<% if (user) { %>, <%= user.name || user.username || 'Student' %>
                                <% } %>!
                    </h1>
                    <p
                        class="text-[#4e5e71] dark:text-gray-400 text-base sm:text-lg font-normal leading-relaxed max-w-[500px]">
                        Manage your hostel services from one place — gate passes, maintenance requests, medical support,
                        and more.
                    </p>
                </div>
            </div>
            <div class="order-1 lg:order-2">
                <div
                    class="relative w-full aspect-[4/3] rounded-2xl overflow-hidden shadow-2xl bg-[#f0f2f4] dark:bg-[#2a343f]">
                    <img alt="Hostel" class="w-full h-full object-cover" src="/images/home.jpg" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- Quick Access Cards -->
    <section class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-10 pb-12 sm:pb-20">
        <h2 class="text-[#111418] dark:text-white text-xl sm:text-2xl font-bold mb-4 sm:mb-6">Quick Access</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
            <a href="/gatepass"
                class="flex flex-col gap-4 p-6 rounded-2xl border border-[#dbe0e6] dark:border-[#2a343f] bg-white dark:bg-[#151f2b] hover:shadow-xl transition-all hover:border-primary/30 group no-underline">
                <div
                    class="size-12 rounded-lg bg-primary/10 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-colors">
                    <span class="material-symbols-outlined text-2xl">badge</span>
                </div>
                <div class="flex flex-col gap-1">
                    <h3 class="text-[#111418] dark:text-white text-lg font-bold">Gate Pass</h3>
                    <p class="text-[#617589] dark:text-gray-400 text-sm">Request or view your gate passes.</p>
                </div>
            </a>
            <a href="/maintenance"
                class="flex flex-col gap-4 p-6 rounded-2xl border border-[#dbe0e6] dark:border-[#2a343f] bg-white dark:bg-[#151f2b] hover:shadow-xl transition-all hover:border-primary/30 group no-underline">
                <div
                    class="size-12 rounded-lg bg-primary/10 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-colors">
                    <span class="material-symbols-outlined text-2xl">build</span>
                </div>
                <div class="flex flex-col gap-1">
                    <h3 class="text-[#111418] dark:text-white text-lg font-bold">Maintenance</h3>
                    <p class="text-[#617589] dark:text-gray-400 text-sm">Submit and track maintenance requests.</p>
                </div>
            </a>
            <a href="/medical"
                class="flex flex-col gap-4 p-6 rounded-2xl border border-[#dbe0e6] dark:border-[#2a343f] bg-white dark:bg-[#151f2b] hover:shadow-xl transition-all hover:border-primary/30 group no-underline">
                <div
                    class="size-12 rounded-lg bg-primary/10 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-colors">
                    <span class="material-symbols-outlined text-2xl">medical_services</span>
                </div>
                <div class="flex flex-col gap-1">
                    <h3 class="text-[#111418] dark:text-white text-lg font-bold">Medical</h3>
                    <p class="text-[#617589] dark:text-gray-400 text-sm">Access medical assistance and records.</p>
                </div>
            </a>
            <a href="/mypasses"
                class="flex flex-col gap-4 p-6 rounded-2xl border border-[#dbe0e6] dark:border-[#2a343f] bg-white dark:bg-[#151f2b] hover:shadow-xl transition-all hover:border-primary/30 group no-underline">
                <div
                    class="size-12 rounded-lg bg-primary/10 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-colors">
                    <span class="material-symbols-outlined text-2xl">history</span>
                </div>
                <div class="flex flex-col gap-1">
                    <h3 class="text-[#111418] dark:text-white text-lg font-bold">My Passes</h3>
                    <p class="text-[#617589] dark:text-gray-400 text-sm">View your pass history and status.</p>
                </div>
            </a>
        </div>
    </section>

    </main>

    <!-- Footer -->
    <%- include('partials/footer') %>
        </body>

        </html>